datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// ==========================================
// 1. Identity & RBAC
// ==========================================

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs              AuditLog[]
  userRoles              UserRole[]
  managedCompanies       Company[]               @relation("AccountManager")
  createdRequisitions    JobRequisition[]        @relation("RequisitionCreator")
  approvedRequisitions   JobRequisition[]        @relation("RequisitionApprover")
  crmActivities          CRMActivity[]
  candidatePools         CandidatePool[]
  assignedApplications   Application[]
  stageLogs              ApplicationStageLog[]
  interviews             Interviewer[]
  feedbacksWritten       InterviewFeedback[]
  approvedOffers         Offer[]                 @relation("OfferApprover")
  createdOffers          Offer[]                 @relation("OfferCreator")
  recordedExpenses       Expense[]
  notifications          SystemNotification[]
  notificationPreference NotificationPreference?
  visaCases              VisaCase[]
  visaStageLogs          VisaStageLog[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String  @id // e.g. "candidates:write"
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  action      String // e.g. "CREATE", "UPDATE", "DELETE"
  resource    String // e.g. "Candidate", "Company"
  resourceId  String
  beforeValue Json?
  afterValue  Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ==========================================
// 2. CRM Module
// ==========================================

enum CompanyStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model Company {
  id               String        @id @default(uuid()) @db.Uuid
  name             String        @unique
  industry         String?
  website          String?
  accountManagerId String?       @db.Uuid
  status           CompanyStatus @default(ACTIVE)
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  accountManager  User?            @relation("AccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)
  contacts        Contact[]
  contracts       Contract[]
  branches        Branch[]
  crmActivities   CRMActivity[]
  jobRequisitions JobRequisition[]
  jobOpenings     JobOpening[]
  invoices        Invoice[]
  visaCases       VisaCase[]

  @@map("companies")
}

model Contact {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @db.Uuid
  firstName   String
  lastName    String
  title       String?
  email       String?
  phone       String?
  linkedinUrl String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities CRMActivity[]

  @@map("contacts")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  id             String         @id @default(uuid()) @db.Uuid
  companyId      String         @db.Uuid
  contractNumber String         @unique
  fileUrl        String
  startDate      DateTime
  endDate        DateTime?
  status         ContractStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("contracts")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @db.Uuid
  name      String
  address   String
  city      String
  country   String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("branches")
}

enum CRMActivityType {
  CALL
  MEETING
  NOTE
  TASK
  FOLLOW_UP
  EMAIL
}

model CRMActivity {
  id          String          @id @default(uuid()) @db.Uuid
  type        CRMActivityType
  subject     String
  content     String
  userId      String          @db.Uuid
  companyId   String?         @db.Uuid
  contactId   String?         @db.Uuid
  candidateId String?         @db.Uuid
  dueDate     DateTime?
  isCompleted Boolean         @default(false)
  createdAt   DateTime        @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact   Contact?   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("crm_activities")
}

// ==========================================
// 3. ATS Module
// ==========================================

enum JobRequisitionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
}

model JobRequisition {
  id              String               @id @default(uuid()) @db.Uuid
  title           String
  department      String
  companyId       String               @db.Uuid
  location        String
  type            JobType
  salaryMin       Decimal?             @db.Decimal(12, 2)
  salaryMax       Decimal?             @db.Decimal(12, 2)
  descriptionEn   String
  descriptionAr   String?
  requirementsEn  String
  requirementsAr      String?
  deadline            DateTime?
  status              JobRequisitionStatus @default(DRAFT)
  creatorId           String               @db.Uuid
  approverId          String?              @db.Uuid
  rejectionReason     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // AI Matching fields
  seniorityLevel      String?  // Junior | Mid | Senior | Lead | Executive
  minExperienceYears  Int?
  requiredSkills      Json?    // [{skill, required, minLevel, minYears}]
  requiredLanguages   Json?    // [{language, level}]

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator    User        @relation("RequisitionCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  approver   User?       @relation("RequisitionApprover", fields: [approverId], references: [id], onDelete: SetNull)
  jobOpening JobOpening?

  @@map("job_requisitions")
}

enum JobOpeningStatus {
  OPEN
  ON_HOLD
  CLOSED
  FILLED
}

model JobOpening {
  id            String                      @id @default(uuid()) @db.Uuid
  requisitionId String                      @unique @db.Uuid
  companyId     String                      @db.Uuid
  title         String
  status        JobOpeningStatus            @default(OPEN)
  openedAt      DateTime                    @default(now())
  closedAt      DateTime?
  embedding     Unsupported("vector(768)")?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  requisition  JobRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  visaCases    VisaCase[]

  @@map("job_openings")
}

enum CandidateAvailability {
  AVAILABLE
  NOTICE_PERIOD
  EMPLOYED
  UNAVAILABLE
}

model Candidate {
  id              String                @id @default(uuid()) @db.Uuid
  firstName       String
  lastName        String
  email           String?               @unique
  phone           String?
  linkedinUrl     String?
  nationality     String?
  currentLocation String?
  expectedSalary  Decimal?              @db.Decimal(12, 2)
  availability         CandidateAvailability @default(AVAILABLE)
  source               String?
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  aiSummary            String?               @db.Text

  // AI Matching fields
  seniorityLevel       String?  // Junior | Mid | Senior | Lead | Executive
  totalYearsExperience Int?
  industryBackground   String?  // e.g. "FinTech, SaaS"
  certifications       Json?    // [{name, issuingOrganization, year}]
  languages            Json?    // [{language, proficiency}]

  // Custom type for vector database search (768 dim for Gemini embeddings)
  embedding Unsupported("vector(768)")?


  experience      CandidateExperience[]
  education       CandidateEducation[]
  skills          CandidateSkill[]
  documents       CandidateDocument[]
  activities      CRMActivity[]
  applications    Application[]
  replacements    Replacement[]
  poolMemberships CandidatePoolMember[]
  visaCases       VisaCase[]

  @@map("candidates")
}

model CandidateExperience {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @db.Uuid
  companyName String
  title       String
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_experience")
}

model CandidateEducation {
  id           String    @id @default(uuid()) @db.Uuid
  candidateId  String    @db.Uuid
  institution  String
  degree       String
  fieldOfStudy String?
  startDate    DateTime
  endDate      DateTime?

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_education")
}

enum SkillProficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model CandidateSkill {
  id          String           @id @default(uuid()) @db.Uuid
  candidateId String           @db.Uuid
  skillName   String
  proficiency SkillProficiency @default(INTERMEDIATE)

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_skills")
}

enum CandidateDocumentType {
  CV
  CERTIFICATE
  PORTFOLIO
  OTHER
}

model CandidateDocument {
  id          String                @id @default(uuid()) @db.Uuid
  candidateId String                @db.Uuid
  type        CandidateDocumentType @default(CV)
  fileName    String
  fileUrl     String
  createdAt   DateTime              @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("candidate_documents")
}

model CandidatePool {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  creatorId   String   @db.Uuid
  createdAt   DateTime @default(now())

  creator User                  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  members CandidatePoolMember[]

  @@map("candidate_pools")
}

model CandidatePoolMember {
  poolId      String @db.Uuid
  candidateId String @db.Uuid

  pool      CandidatePool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  candidate Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@id([poolId, candidateId])
  @@map("candidate_pool_members")
}

// ==========================================
// 4. Recruitment Pipeline
// ==========================================

enum ApplicationStage {
  NEW_APPLICATION
  SCREENING
  HR_INTERVIEW
  TECHNICAL_INTERVIEW
  ASSESSMENT
  OFFER
  PLACEMENT
  REJECTED
  WITHDRAWN
}

model Application {
  id           String           @id @default(uuid()) @db.Uuid
  candidateId  String           @db.Uuid
  jobOpeningId String           @db.Uuid
  recruiterId  String           @db.Uuid
  stage        ApplicationStage @default(NEW_APPLICATION)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  candidate  Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOpening JobOpening            @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  recruiter  User                  @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  stageLogs  ApplicationStageLog[]
  interviews Interview[]
  offers     Offer[]
  placements Placement[]

  @@unique([candidateId, jobOpeningId])
  @@map("applications")
}

model ApplicationStageLog {
  id            String            @id @default(uuid()) @db.Uuid
  applicationId String            @db.Uuid
  fromStage     ApplicationStage?
  toStage       ApplicationStage
  note          String?
  userId        String            @db.Uuid
  createdAt     DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("application_stage_logs")
}

// ==========================================
// 5. Interviews & Offers
// ==========================================

enum InterviewType {
  HR
  TECHNICAL
  FINAL
  ASSESSMENT
  CLIENT
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

model Interview {
  id                 String          @id @default(uuid()) @db.Uuid
  applicationId      String          @db.Uuid
  type               InterviewType
  scheduledAt        DateTime
  location           String?
  videoLink          String?
  status             InterviewStatus @default(SCHEDULED)
  cancellationReason String?
  createdAt          DateTime        @default(now())

  application  Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewers Interviewer[]
  feedbacks    InterviewFeedback[]

  @@map("interviews")
}

model Interviewer {
  interviewId String @db.Uuid
  userId      String @db.Uuid

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([interviewId, userId])
  @@map("interviewers")
}

enum RecommendationStatus {
  HIRE
  HOLD
  REJECT
}

model InterviewFeedback {
  id                String               @id @default(uuid()) @db.Uuid
  interviewId       String               @db.Uuid
  interviewerId     String               @db.Uuid
  recommendation    RecommendationStatus
  notes             String?
  competencyRatings Json
  createdAt         DateTime             @default(now())

  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewer User      @relation(fields: [interviewerId], references: [id], onDelete: Cascade)

  @@map("interview_feedbacks")
}

enum OfferStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Offer {
  id              String      @id @default(uuid()) @db.Uuid
  applicationId   String      @db.Uuid
  salaryAmount    Decimal     @db.Decimal(12, 2)
  currency        String
  benefits        String?
  startDate       DateTime
  expiryDate      DateTime
  status          OfferStatus @default(DRAFT)
  rejectionReason String?
  creatorId       String      @db.Uuid
  approverId      String?     @db.Uuid
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  creator     User        @relation("OfferCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  approver    User?       @relation("OfferApprover", fields: [approverId], references: [id], onDelete: SetNull)
  placement   Placement?

  @@map("offers")
}

// ==========================================
// 6. Placement & Replacement
// ==========================================

enum GuaranteeStatus {
  ACTIVE
  AT_RISK
  EXPIRED
  VOIDED
}

enum PlacementStatus {
  ACTIVE
  GUARANTEE_PERIOD
  COMPLETED
  REPLACED
}

model Placement {
  id               String          @id @default(uuid()) @db.Uuid
  offerId          String          @unique @db.Uuid
  applicationId    String          @db.Uuid
  startDate        DateTime
  feeAmount        Decimal         @db.Decimal(12, 2)
  feeType          String // FIXED or PERCENTAGE
  guaranteeDays    Int             @default(90)
  guaranteeEndDate DateTime
  guaranteeStatus  GuaranteeStatus @default(ACTIVE)
  status           PlacementStatus @default(GUARANTEE_PERIOD)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  offer        Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  application  Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  replacements Replacement[]
  invoices     Invoice[]
  visaCase     VisaCase?

  @@map("placements")
}

enum ReplacementReason {
  PERFORMANCE
  CULTURAL_FIT
  RESIGNATION
  TERMINATION
  MEDICAL
  OTHER
}

enum ReplacementStatus {
  REQUESTED
  IN_PROGRESS
  COMPLETED
}

model Replacement {
  id                     String            @id @default(uuid()) @db.Uuid
  placementId            String            @db.Uuid
  replacementCandidateId String?           @db.Uuid
  reason                 ReplacementReason
  detailNotes            String?
  status                 ReplacementStatus @default(REQUESTED)
  createdAt              DateTime          @default(now())
  completedAt            DateTime?

  placement            Placement  @relation(fields: [placementId], references: [id], onDelete: Cascade)
  replacementCandidate Candidate? @relation(fields: [replacementCandidateId], references: [id], onDelete: SetNull)

  @@map("replacements")
}

// ==========================================
// 7. Finance Module
// ==========================================

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id                 String        @id @default(uuid()) @db.Uuid
  placementId        String?       @db.Uuid
  invoiceNumber      String        @unique // e.g. INV-2025-001
  companyId          String        @db.Uuid
  issueDate          DateTime
  dueDate            DateTime
  subtotal           Decimal       @db.Decimal(12, 2)
  vatAmount          Decimal       @db.Decimal(12, 2)
  totalAmount        Decimal       @db.Decimal(12, 2)
  status             InvoiceStatus @default(DRAFT)
  cancellationReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  placement Placement?    @relation(fields: [placementId], references: [id], onDelete: SetNull)
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items     InvoiceItem[]
  payments  Payment[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @db.Uuid
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

enum PaymentMethod {
  BANK_TRANSFER
  CHECK
  CASH
  CREDIT_CARD
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  invoiceId       String        @db.Uuid
  amount          Decimal       @db.Decimal(12, 2)
  paymentDate     DateTime
  paymentMethod   PaymentMethod
  referenceNumber String?
  createdAt       DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum ExpenseCategory {
  OFFICE
  TRAVEL
  MARKETING
  SOFTWARE
  UTILITIES
  OTHER
}

model Expense {
  id           String          @id @default(uuid()) @db.Uuid
  category     ExpenseCategory
  description  String
  amount       Decimal         @db.Decimal(12, 2)
  expenseDate  DateTime
  recordedById String          @db.Uuid
  createdAt    DateTime        @default(now())

  recordedBy User @relation(fields: [recordedById], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ==========================================
// 8. Notifications & Preferences
// ==========================================

model NotificationPreference {
  userId       String  @id @db.Uuid
  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model SystemNotification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String // e.g. "GUARANTEE_EXPIRY", "INVOICE_OVERDUE"
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("system_notifications")
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  group     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ==========================================
// 9. Visa Processing Module
// ==========================================

model VisaWorkflow {
  id          String   @id @default(uuid()) @db.Uuid
  country     String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages    VisaWorkflowStage[]
  visaCases VisaCase[]

  @@map("visa_workflows")
}

model VisaWorkflowStage {
  id             String   @id @default(uuid()) @db.Uuid
  workflowId     String   @db.Uuid
  name           String // e.g., "Medical", "Biometrics"
  order          Int
  checklistItems Json? // Array of predefined checklist items
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workflow           VisaWorkflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  casesCurrentlyHere VisaCase[]
  stageLogs          VisaStageLog[]

  @@map("visa_workflow_stages")
}

model VisaCase {
  id             String  @id @default(uuid()) @db.Uuid
  placementId    String  @unique @db.Uuid
  candidateId    String  @db.Uuid
  jobId          String  @db.Uuid
  companyId      String  @db.Uuid
  workflowId     String? @db.Uuid
  currentStageId String? @db.Uuid
  coordinatorId  String? @db.Uuid

  country          String?
  visaNumber       String?
  passportNumber   String?
  embassy          String?
  visaType         String?
  workPermitNumber String?
  medicalStatus    String?

  travelDate  DateTime?
  arrivalDate DateTime?

  status VisaCaseStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  placement    Placement          @relation(fields: [placementId], references: [id], onDelete: Cascade)
  candidate    Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOpening   JobOpening         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workflow     VisaWorkflow?      @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  currentStage VisaWorkflowStage? @relation(fields: [currentStageId], references: [id], onDelete: SetNull)
  coordinator  User?              @relation(fields: [coordinatorId], references: [id], onDelete: SetNull)

  documents VisaDocument[]
  stageLogs VisaStageLog[]

  @@map("visa_cases")
}

enum VisaCaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
  REJECTED
  CANCELLED
}

model VisaDocument {
  id         String         @id @default(uuid()) @db.Uuid
  visaCaseId String         @db.Uuid
  type       String // e.g., "Passport", "Medical Report"
  status     DocumentStatus @default(PENDING)
  fileUrl    String?
  expiryDate DateTime?
  uploadedAt DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  visaCase VisaCase @relation(fields: [visaCaseId], references: [id], onDelete: Cascade)

  @@map("visa_documents")
}

enum DocumentStatus {
  PENDING
  UPLOADED
  REJECTED
  EXPIRED
}

model VisaStageLog {
  id             String    @id @default(uuid()) @db.Uuid
  visaCaseId     String    @db.Uuid
  stageId        String    @db.Uuid
  completedById  String?   @db.Uuid
  status         String // e.g., "COMPLETED", "SKIPPED", "PENDING"
  notes          String?
  checklistState Json? // Tracks which checklist items were ticked
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  visaCase    VisaCase          @relation(fields: [visaCaseId], references: [id], onDelete: Cascade)
  stage       VisaWorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  completedBy User?             @relation(fields: [completedById], references: [id], onDelete: SetNull)

  @@map("visa_stage_logs")
}
